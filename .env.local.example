NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Stock API（stock-winning-rate）：本機預設 http://127.0.0.1:8765
ANTIGRAVITY_API_URL=http://127.0.0.1:8765
# STT（AI_Speech/stt）：本機 make serve 預設 http://127.0.0.1:8787
# 正式站（Vercel）可不設定，會自動用瀏覽器語音辨識
# 若 Whisper 有公網 URL：STT_API_URL=https://stt.yourdomain.com
STT_API_URL=http://127.0.0.1:8787

# Email (Gmail SMTP)
# 1) 請先替 Gmail 帳號開啟 2FA，並建立「應用程式密碼」(App Password)
# 2) SMTP_USER 填 Gmail，SMTP_PASS 填 App Password（不是登入密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=wenliangmatt@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Optional：若不填則預設用 SMTP_USER
EMAIL_FROM="Stock Report <wenliangmatt@gmail.com>"
